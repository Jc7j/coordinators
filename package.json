  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "start:test": "next start -p 3137",
    "lint": "eslint",
    "typecheck": "tsc --noEmit",
    "format": "prettier --write .",
